###
### USUARIOS
###

### Registro Usuario
POST {{baseUrl}}/api/usuarios/registro
Content-Type: application/json

{
  "email": "usuario@viandas.com",
  "password": "123456",
  "nombre": "Usuario Test"
}

### Login
POST {{baseUrl}}/api/usuarios/login
Content-Type: application/json

{
  "email": "admin@viandas.com",
  "password": "123456"
}

### Obtener Mi Perfil
GET {{baseUrl}}/api/usuarios/perfil
Authorization: Bearer {{token}}

### Obtener Todos los Usuarios
GET {{baseUrl}}/api/usuarios
Authorization: Bearer {{token}}

###
### CLIENTES
###

### Crear Cliente
POST {{baseUrl}}/api/clientes
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "nombre": "Juan",
  "apellido": "Perez",
  "telefono": "1234567890",
  "direccion": "Calle 123",
  "zona": "SAN_LORENZO",
  "preferenciaEntrega": "DOMICILIO"
}

### Obtener Todos los Clientes
GET {{baseUrl}}/api/clientes
Authorization: Bearer {{token}}

### Obtener Cliente por ID (id 1)
GET {{baseUrl}}/api/clientes/1
Authorization: Bearer {{token}}

### Obtener Clientes por Zona
GET {{baseUrl}}/api/clientes/zona/SAN_LORENZO
Authorization: Bearer {{token}}

### Actualizar Cliente (id 1)
PUT {{baseUrl}}/api/clientes/1
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "nombre": "Juan Updated",
  "apellido": "Perez Updated"
}

### Eliminar Cliente (id 1)
DELETE {{baseUrl}}/api/clientes/1
Authorization: Bearer {{token}}

###
### MENUS
###

### Crear Menu
POST {{baseUrl}}/api/menus
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "fechaInicioSemana": "2026-04-07T00:00:00Z",
  "fechaCierrePedidos": "2026-04-05T23:59:59Z",
  "estado": "BORRADOR",
  "precioBase": 150.00,
  "costoEnvio": 50.00
}

### Obtener Todos los Menus
GET {{baseUrl}}/api/menus

### Obtener Menus Activos
GET {{baseUrl}}/api/menus/activos

### Obtener Menu por ID (id 1)
GET {{baseUrl}}/api/menus/1

### Actualizar Menu (id 1)
PUT {{baseUrl}}/api/menus/1
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "estado": "PUBLICADO"
}

### Eliminar Menu (id 1)
DELETE {{baseUrl}}/api/menus/1
Authorization: Bearer {{token}}

###
### PEDIDOS
###

### Crear Pedido
POST {{baseUrl}}/api/pedidos
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "numeroPedido": "PED-001",
  "clienteId": 1,
  "menuId": 1,
  "fechaEntrega": "2026-04-08T10:00:00Z",
  "tipoEntrega": "DOMICILIO",
  "total": 200.00
}

### Obtener Todos los Pedidos
GET {{baseUrl}}/api/pedidos
Authorization: Bearer {{token}}

### Obtener Pedido por ID (id 1)
GET {{baseUrl}}/api/pedidos/1
Authorization: Bearer {{token}}

### Obtener Pedidos por Cliente (clienteId 1)
GET {{baseUrl}}/api/pedidos/cliente/1
Authorization: Bearer {{token}}

### Obtener Pedidos por Estado
GET {{baseUrl}}/api/pedidos/estado/PENDIENTE
Authorization: Bearer {{token}}

### Actualizar Pedido (id 1)
PUT {{baseUrl}}/api/pedidos/1
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "estado": "CONFIRMADO"
}

### Eliminar Pedido (id 1)
DELETE {{baseUrl}}/api/pedidos/1
Authorization: Bearer {{token}}

###
### RECETAS
###

### Crear Receta
POST {{baseUrl}}/api/recetas
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "nombrePlato": "Pechuga a la Plancha",
  "descripcion": "Pechuga de pollo jugosa con vegetales",
  "tipo": "CARNIVORO",
  "diaSemana": "LUNES",
  "calorias": 450,
  "menuId": 1
}

### Obtener Todas las Recetas
GET {{baseUrl}}/api/recetas

### Obtener Receta por ID (id 1)
GET {{baseUrl}}/api/recetas/1

### Obtener Recetas por Menu (menuId 1)
GET {{baseUrl}}/api/recetas/menu/1

### Actualizar Receta (id 1)
PUT {{baseUrl}}/api/recetas/1
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "nombrePlato": "Pechuga a la Plancha - Actualizada",
  "calorias": 500
}

### Eliminar Receta (id 1)
DELETE {{baseUrl}}/api/recetas/1
Authorization: Bearer {{token}}

### Agregar Ingrediente a Receta (recetaId 1)
POST {{baseUrl}}/api/recetas/1/ingredientes
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "ingredienteId": 1,
  "cantidad": 250
}

### Obtener Ingredientes de Receta (recetaId 1)
GET {{baseUrl}}/api/recetas/1/ingredientes

### Eliminar Ingrediente de Receta (recetaId 1, ingredienteId 1)
DELETE {{baseUrl}}/api/recetas/1/ingredientes/1
Authorization: Bearer {{token}}

###
### INGREDIENTES
###

### Crear Ingrediente
POST {{baseUrl}}/api/ingredientes
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "nombre": "Pechuga de Pollo",
  "unidadMedida": "gramos",
  "costoUnitario": 8.50,
  "categoria": "PROTEINA"
}

### Obtener Todos los Ingredientes
GET {{baseUrl}}/api/ingredientes

### Obtener Ingrediente por ID (id 1)
GET {{baseUrl}}/api/ingredientes/1

### Obtener Ingredientes por Categoría
GET {{baseUrl}}/api/ingredientes/categoria/PROTEINA

### Actualizar Ingrediente (id 1)
PUT {{baseUrl}}/api/ingredientes/1
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "costoUnitario": 9.00
}

### Eliminar Ingrediente (id 1)
DELETE {{baseUrl}}/api/ingredientes/1
Authorization: Bearer {{token}}